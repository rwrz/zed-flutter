[
  {
    "label": "Pubspec — pub get",
    "command": "flutter",
    "args": [
      "pub",
      "get"
    ],
    "cwd": "$ZED_DIRNAME",
    "tags": [
      "pubspec"
    ],
    "reveal": "always",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "save": "current"
  },
